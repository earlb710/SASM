; Example 07 — Conditional Comparison Chain (Sign Function)
; Categorize the signed 16-bit value in ax as negative, zero, or positive.
; Stores −1 (0xFFFF), 0, or +1 in bx respectively.

proc sign_of_ax {
    compare ax with 0
    if less {
        move 0xFFFF to bx    ; -1 as a 16-bit two's complement word
    } else if equal {
        move 0 to bx
    } else {
        move 1 to bx
    }
    return
}
