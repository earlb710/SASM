; Example 04 — Find Highest Set Bit
; Scan bx from MSB downward for the first set bit.
; Returns the zero-based bit position in cx.
; If bx is 0 (no bits set), cx is set to 0xFFFF as a sentinel.

proc highest_bit:
    test bx and bx
    if equal {
        move 0xFFFF to cx    ; signal: no bits set
        return
    }
    scan reverse bx into cx
    return
end proc
