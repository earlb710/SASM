// io.sasm
// Windows File I/O Library — standard library for reading and writing files.
//
// This library wraps Win32 kernel32.dll API calls for file operations
// on 32-bit Windows (PE32 console executables).

#COMPAT Windows 95, 98, ME
#COMPAT Windows NT 3.1, 3.51, 4.0
#COMPAT Windows 2000, XP, Vista, 7, 8, 8.1, 10, 11
#COMPAT Windows XP x64, Vista x64, 7 x64, 8 x64, 8.1 x64, 10 x64, 11 x64 (via WoW64)

//
// ── Windows Version Compatibility ───────────────────────────────
//
// The Win32 API functions used by this library (CreateFileA, ReadFile,
// WriteFile, CloseHandle, GetStdHandle) are core kernel32.dll exports
// available on every 32-bit and 64-bit version of Windows:
//
//   32-bit (native):
//     Windows 95, 98, ME
//     Windows NT 3.1, 3.51, 4.0
//     Windows 2000, XP, Vista, 7, 8, 8.1, 10, 11
//
//   64-bit (via WoW64 — Windows-on-Windows 64-bit):
//     Windows XP x64, Vista x64, 7 x64, 8 x64, 8.1 x64, 10 x64, 11 x64
//
// In short: any version of Windows from Windows 95 / NT 3.1 onward.
// On 64-bit Windows the 32-bit executable runs under the WoW64
// compatibility layer automatically — no source changes needed.
//
// The "A" (ANSI) variants of the API are used (CreateFileA, not
// CreateFileW) so file paths are ANSI-encoded, not Unicode.
//
// ── Usage ───────────────────────────────────────────────────────
//
//     #REF lib/io.sasm io
//
//     call @io.open_file_read       // open for reading
//     call @io.read_file            // read bytes
//     call @io.write_file           // write bytes
//     call @io.close_file           // close handle
//     call @io.create_file_write    // create/truncate for writing
//     call @io.write_stdout         // write to console stdout
//
// All procedures follow the Windows stdcall convention where the
// Win32 API cleans the stack.  Callers push arguments right-to-left
// and the API pops them on return.
//
// Win32 handles are 32-bit DWORD values returned in eax.
// Error returns:  eax = -1 (INVALID_HANDLE_VALUE) or eax = 0 (FALSE).
//
// Register conventions:
//   eax — return value / handle / success flag
//   ecx, edx — scratch (caller-saved, clobbered by API calls)
//   ebx, esi, edi, ebp — callee-saved (preserved by these wrappers)

section .data

// ── Win32 Constants ─────────────────────────────────────────────

// Generic access rights
io_GENERIC_READ         equ 0x80000000
io_GENERIC_WRITE        equ 0x40000000
io_GENERIC_READ_WRITE   equ 0xC0000000

// Share modes
io_FILE_SHARE_READ      equ 0x00000001
io_FILE_SHARE_WRITE     equ 0x00000002

// Creation dispositions
io_CREATE_NEW           equ 1
io_CREATE_ALWAYS        equ 2
io_OPEN_EXISTING        equ 3
io_OPEN_ALWAYS          equ 4
io_TRUNCATE_EXISTING    equ 5

// File attributes
io_FILE_ATTRIBUTE_NORMAL equ 0x00000080

// Standard handles for GetStdHandle
io_STD_INPUT_HANDLE     equ -10
io_STD_OUTPUT_HANDLE    equ -11
io_STD_ERROR_HANDLE     equ -12

// INVALID_HANDLE_VALUE
io_INVALID_HANDLE       equ -1

section .text

// ── external Win32 API imports ──────────────────────────────────
extern _CreateFileA@28
extern _ReadFile@20
extern _WriteFile@20
extern _CloseHandle@4
extern _GetStdHandle@4

// ── open_file_read ──────────────────────────────────────────────
// Opens an existing file for reading.
//
// Input:
//   [esp+4] = pointer to null-terminated file path (LPCSTR)
//
// Output:
//   eax = file handle, or -1 (INVALID_HANDLE_VALUE) on error
//
// Clobbers: ecx, edx (per stdcall)
//
// Example:
//   push file_path
//   call @io.open_file_read
//   // eax = handle (check for io_INVALID_HANDLE)
io_open_file_read:
    push ebp
    move esp to ebp

    push 0                            // hTemplateFile = NULL
    push io_FILE_ATTRIBUTE_NORMAL     // dwFlagsAndAttributes
    push io_OPEN_EXISTING             // dwCreationDisposition
    push 0                            // lpSecurityAttributes = NULL
    push io_FILE_SHARE_READ           // dwShareMode
    push io_GENERIC_READ              // dwDesiredAccess
    push dword [ebp+8]               // lpFileName (file path from caller)
    call _CreateFileA@28

    pop ebp
    return

// ── create_file_write ───────────────────────────────────────────
// Creates or truncates a file for writing.
//
// Input:
//   [esp+4] = pointer to null-terminated file path (LPCSTR)
//
// Output:
//   eax = file handle, or -1 (INVALID_HANDLE_VALUE) on error
//
// Clobbers: ecx, edx (per stdcall)
//
// Example:
//   push output_path
//   call @io.create_file_write
//   // eax = handle
io_create_file_write:
    push ebp
    move esp to ebp

    push 0                            // hTemplateFile = NULL
    push io_FILE_ATTRIBUTE_NORMAL     // dwFlagsAndAttributes
    push io_CREATE_ALWAYS             // dwCreationDisposition
    push 0                            // lpSecurityAttributes = NULL
    push 0                            // dwShareMode = 0 (exclusive)
    push io_GENERIC_WRITE             // dwDesiredAccess
    push dword [ebp+8]               // lpFileName (file path from caller)
    call _CreateFileA@28

    pop ebp
    return

// ── read_file ───────────────────────────────────────────────────
// Reads bytes from an open file handle.
//
// Input:
//   [esp+4]  = file handle (HANDLE)
//   [esp+8]  = pointer to destination buffer (LPVOID)
//   [esp+12] = number of bytes to read (DWORD)
//
// Output:
//   eax = 1 (TRUE) on success, 0 (FALSE) on failure
//   The actual number of bytes read is stored in a local variable;
//   callers who need it should pass their own lpBytesRead pointer
//   or use read_file_ex below.
//
// Clobbers: ecx, edx
//
// Example:
//   push 256                         // nNumberOfBytesToRead
//   push buffer                      // lpBuffer
//   push eax                         // hFile (handle from open)
//   call @io.read_file
//   // eax = TRUE/FALSE
io_read_file:
    push ebp
    move esp to ebp
    subtract 4 from esp               // local: bytes_read (DWORD)

    push 0                            // lpOverlapped = NULL
    address of ebp-4 to eax
    push eax                          // lpNumberOfBytesRead
    push dword [ebp+16]              // nNumberOfBytesToRead
    push dword [ebp+12]              // lpBuffer
    push dword [ebp+8]               // hFile
    call _ReadFile@20

    move ebp to esp
    pop ebp
    return

// ── write_file ──────────────────────────────────────────────────
// Writes bytes to an open file handle.
//
// Input:
//   [esp+4]  = file handle (HANDLE)
//   [esp+8]  = pointer to data buffer (LPCVOID)
//   [esp+12] = number of bytes to write (DWORD)
//
// Output:
//   eax = 1 (TRUE) on success, 0 (FALSE) on failure
//
// Clobbers: ecx, edx
//
// Example:
//   push 5                           // nNumberOfBytesToWrite
//   push msg                         // lpBuffer
//   push eax                         // hFile (handle from open/create)
//   call @io.write_file
//   // eax = TRUE/FALSE
io_write_file:
    push ebp
    move esp to ebp
    subtract 4 from esp               // local: bytes_written (DWORD)

    push 0                            // lpOverlapped = NULL
    address of ebp-4 to eax
    push eax                          // lpNumberOfBytesWritten
    push dword [ebp+16]              // nNumberOfBytesToWrite
    push dword [ebp+12]              // lpBuffer
    push dword [ebp+8]               // hFile
    call _WriteFile@20

    move ebp to esp
    pop ebp
    return

// ── close_file ──────────────────────────────────────────────────
// Closes an open file handle.
//
// Input:
//   [esp+4] = file handle (HANDLE)
//
// Output:
//   eax = 1 (TRUE) on success, 0 (FALSE) on failure
//
// Clobbers: ecx, edx
//
// Example:
//   push eax                         // hObject (file handle)
//   call @io.close_file
io_close_file:
    push ebp
    move esp to ebp

    push dword [ebp+8]               // hObject
    call _CloseHandle@4

    pop ebp
    return

// ── write_stdout ────────────────────────────────────────────────
// Writes a message to the console standard output.
//
// Input:
//   [esp+4] = pointer to data buffer (LPCVOID)
//   [esp+8] = number of bytes to write (DWORD)
//
// Output:
//   eax = 1 (TRUE) on success, 0 (FALSE) on failure
//
// Clobbers: ecx, edx
//
// Example:
//   push 13                          // length
//   push hello_msg                   // buffer
//   call @io.write_stdout
io_write_stdout:
    push ebp
    move esp to ebp
    subtract 4 from esp               // local: bytes_written (DWORD)

    // Get stdout handle
    push io_STD_OUTPUT_HANDLE
    call _GetStdHandle@4
    // eax = stdout handle

    // WriteFile(stdout, buffer, length, &written, NULL)
    push 0                            // lpOverlapped = NULL
    address of ebp-4 to ecx
    push ecx                          // lpNumberOfBytesWritten
    push dword [ebp+12]              // nNumberOfBytesToWrite
    push dword [ebp+8]               // lpBuffer
    push eax                          // hFile = stdout handle
    call _WriteFile@20

    move ebp to esp
    pop ebp
    return
