// testCompat.sasm
// Tests the #COMPAT OS-compatibility directive.
//
// Verifies that #COMPAT lines are translated to NASM comments
// and do not interfere with other directives or code.

#COMPAT Windows 10, 11
#COMPAT Linux x86_64 (syscall ABI)

section .data

var msg as byte[6]
data msg_bytes as byte = 'H','e','l','l','o',0

section .text
global _start

_start:
    move msg_bytes to ax
    halt
