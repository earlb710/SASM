// testInlineProc.sasm
// Tests the "inline" attribute on proc declarations.
//
// An inline proc's body is expanded at each call site instead of
// generating a CALL/RET sequence.  This avoids the overhead of
// a function call for small, frequently-used utility routines.

#COMPAT Linux x86 (i386, int 0x80 ABI)

section .data

data expected_square as dword = 49   // 7 * 7
data expected_double as dword = 14   // 7 + 7
data expected_sum    as dword = 30   // 10 + 20

section .bss

var result_square as dword
var result_double as dword
var result_sum    as dword

section .text

// ── inline proc: double_val ──────────────────────────────────
// Doubles the value in reg1 by adding it to itself.
//
// in  reg1 = value to double
// out reg1 = value * 2
inline proc double_val (val dword value) out val dword {
    reg1 = reg1 + reg1
    return
}

// ── inline proc: square_val ──────────────────────────────────
// Squares the unsigned value in reg1.
//
// in  reg1 = value to square (unsigned)
// out reg1 = value * value (low 32 bits)
// clobbers reg4
inline proc square_val (val dword value) out val dword {
    multiply by reg1
    return
}

// ── inline proc: add_regs ────────────────────────────────────
// Adds reg2 to reg1.
//
// in  reg1 = first operand
// in  reg2 = second operand
// out reg1 = first + second
inline proc add_regs (val dword first, val dword second) out val dword {
    reg1 = reg1 + reg2
    return
}

// ── regular proc for comparison ──────────────────────────────
// A regular (non-inline) proc that doubles reg1.  Generates a
// CALL/RET pair.
proc double_regular (val dword value) out val dword {
    reg1 = reg1 + reg1
    return
}

global _start

proc _start {
    // Test 1: inline square — 7 * 7 = 49
    move 7 to reg1
    call square_val
    move reg1 to dword [result_square]

    // Test 2: inline double — 7 + 7 = 14
    move 7 to reg1
    call double_val
    move reg1 to dword [result_double]

    // Test 3: inline add_regs — 10 + 20 = 30
    move 10 to reg1
    move 20 to reg2
    call add_regs
    move reg1 to dword [result_sum]

    // Test 4: regular (non-inline) double — still uses CALL
    move 7 to reg1
    call double_regular

    // exit
    move 1 to reg1
    move 0 to reg2
    interrupt 0x80
}
