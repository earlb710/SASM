// testInlineProc.sasm
// Tests the "inline" attribute on proc declarations.
//
// An inline proc's body is expanded at each call site instead of
// generating a CALL/RET sequence.  This avoids the overhead of
// a function call for small, frequently-used utility routines.

#COMPAT Linux x86 (i386, int 0x80 ABI)

section .data

data expected_square as dword = 49   // 7 * 7
data expected_double as dword = 14   // 7 + 7
data expected_sum    as dword = 30   // 10 + 20

section .bss

var result_square as dword
var result_double as dword
var result_sum    as dword

section .text

// ── inline proc: double_val ──────────────────────────────────
// Doubles the value in EAX by adding it to itself.
//
// in  EAX = value to double
// out EAX = value * 2
inline proc double_val ( in eax as value, out eax as result ) {
    eax = eax + eax
    return
}

// ── inline proc: square_val ──────────────────────────────────
// Squares the unsigned value in EAX.
//
// in  EAX = value to square (unsigned)
// out EAX = value * value (low 32 bits)
// clobbers EDX
inline proc square_val ( in eax as value, out eax as result ) {
    multiply by eax
    return
}

// ── inline proc: add_regs ────────────────────────────────────
// Adds EBX to EAX.
//
// in  EAX = first operand
// in  EBX = second operand
// out EAX = first + second
inline proc add_regs ( in eax as first, in ebx as second, out eax as result ) {
    eax = eax + ebx
    return
}

// ── regular proc for comparison ──────────────────────────────
// A regular (non-inline) proc that doubles EAX.  Generates a
// CALL/RET pair.
proc double_regular ( in eax as value, out eax as result ) {
    eax = eax + eax
    return
}

global _start

proc _start {
    // Test 1: inline square — 7 * 7 = 49
    move 7 to eax
    call square_val
    move eax to dword [result_square]

    // Test 2: inline double — 7 + 7 = 14
    move 7 to eax
    call double_val
    move eax to dword [result_double]

    // Test 3: inline add_regs — 10 + 20 = 30
    move 10 to eax
    move 20 to ebx
    call add_regs
    move eax to dword [result_sum]

    // Test 4: regular (non-inline) double — still uses CALL
    move 7 to eax
    call double_regular

    // exit
    move 1 to eax
    move 0 to ebx
    interrupt 0x80
}
