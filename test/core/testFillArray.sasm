// testFillArray.sasm
// Project : Test-projects
//
// Fills a 10-element byte array with the value 0xAA,
// then sums the elements to verify the fill.
// Also demonstrates the var array syntax for memory allocation.

section .text
global _start

(* //---------------------------------------------------------------
   Static data array: 10 zero-initialized bytes that we will fill.
   //--------------------------------------------------------------- *)
data buffer as byte[10]

(* //---------------------------------------------------------------
   Var-declared arrays — same TIMES output, uses "var" keyword.
   //--------------------------------------------------------------- *)
var localBuf  as byte[16]              // 16 bytes, zero-initialized
var wordTable as word[8]               // 8 words, zero-initialized
var dwordArr  as dword[4]              // 4 dwords, zero-initialized
var fillBuf   as byte[10] = 0xFF      // 10 bytes, each set to 0xFF

(* //---------------------------------------------------------------
   fill_array — fills 'buffer' with the value in reg1.b (10 elements).
   //--------------------------------------------------------------- *)
proc fill_array {
    move 0 to reg2.w                      // reg2.w = byte index
    move 10 to reg3.w                     // reg3.w = element count
    repeat reg3.w times {
        move reg1.b to byte [buffer + reg2.w] // buffer[reg2.w] = reg1.b
        increment reg2.w
    }
    return
}

(* //---------------------------------------------------------------
   sum_array — returns the sum of 'buffer' (10 bytes) in reg1.w.
   //--------------------------------------------------------------- *)
proc sum_array {
    move 0 to reg1.w                      // reg1.w = accumulator
    move 0 to reg2.w                      // reg2.w = byte index
    move 10 to reg3.w                     // reg3.w = element count
    repeat reg3.w times {
        move byte [buffer + reg2.w] to reg4.b
        move zero reg4.b to reg4.w            // zero-extend byte → word
        reg1.w = reg1.w + reg4.w
        increment reg2.w
    }
    return
}

(* //---------------------------------------------------------------
   _start — entry point
   Fill the array with 0xAA, then sum to verify.
   Expected sum: 10 * 0xAA = 10 * 170 = 1700 (0x06A4).
   //--------------------------------------------------------------- *)
_start:
    move 0xAA to reg1.b                   // fill value
    call fill_array                   // buffer[0..9] = 0xAA

    call sum_array                    // reg1.w = 1700 (0x06A4)

    // Exit (Linux syscall: sys_exit with status in reg2.b)
    move reg1.b to reg2.b                     // exit code = low byte of sum (0xA4)
    move 1 to reg1.w                      // sys_exit
    syscall 0x80
