-- testMultiDimArrays.sasm
-- Project : Test-projects
--
-- Tests multi-dimensional array declarations for var and data keywords.
-- Verifies that the translator computes the total element count as the
-- product of all dimensions (e.g. [3][4] = 12 elements).

section .text
global _start

(* -----------------------------------------------------------------
   Static multi-dimensional arrays (data segment).
   ----------------------------------------------------------------- *)
data screen as byte[25][80]              -- 25 rows × 80 cols = 2000 bytes
data grid   as word[4][4]                -- 4×4 = 16 words

(* -----------------------------------------------------------------
   Var-declared multi-dimensional arrays (same TIMES output).
   ----------------------------------------------------------------- *)
var matrix  as byte[3][4]                -- 3×4 = 12 bytes,  zero-initialized
var table2d as word[5][10]               -- 5×10 = 50 words, zero-initialized
var cube    as dword[2][3][4]            -- 2×3×4 = 24 dwords, zero-initialized
var initMat as byte[3][4] = 0xFF        -- 3×4 = 12 bytes, each set to 0xFF
var signMat as word[2][3] signed         -- 2×3 = 6 words, signed, zero-initialized
var signInit as word[2][3] signed = -1   -- 2×3 = 6 words, signed, each set to -1

(* -----------------------------------------------------------------
   1D arrays should still work as before.
   ----------------------------------------------------------------- *)
data buffer as byte[10]
var  localBuf as byte[16]
var  fillBuf  as byte[10] = 0xAA

(* -----------------------------------------------------------------
   Scalars should still work as before.
   ----------------------------------------------------------------- *)
var counter as word
var flag    as byte = 1

(* -----------------------------------------------------------------
   fill_matrix — fills 'matrix' (3×4 = 12 bytes) with the value in al.
   Demonstrates accessing a multi-dimensional array as flat memory.
   ----------------------------------------------------------------- *)
proc fill_matrix {
    move 0 to bx                          -- bx = byte index
    move 12 to cx                         -- cx = total element count (3×4)
    repeat cx times {
        move al to byte [matrix + bx]     -- matrix[bx] = al
        increment bx
    }
    return
}

(* -----------------------------------------------------------------
   _start — entry point
   Fill the 3×4 matrix with 0x42, then read an element to verify.
   ----------------------------------------------------------------- *)
_start:
    move 0x42 to al                       -- fill value
    call fill_matrix                      -- matrix[0..11] = 0x42

    -- Read matrix[1][2] (row 1, col 2 = byte offset 1*4 + 2 = 6)
    move 6 to bx
    move byte [matrix + bx] to dl         -- dl = 0x42

    -- Exit
    move dl to bl
    move 1 to ax
    syscall 0x80
