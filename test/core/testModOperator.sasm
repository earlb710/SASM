// Test: Modulo operator (%, mod, smod)
//
// Verifies that the modulo operator generates the correct NASM output.
// Modulo uses DIV/IDIV like division but returns the remainder
// from the high register (reg4.w/reg4/RDX) instead of the quotient.

section .data
    var dividend as word = 17
    var divisor  as word = 5

section .text

// ── % operator (unsigned modulo) ─────────────────────────────────
// 17 % 5 = 2

// 16-bit: remainder in reg4.w
reg1.w = reg3.w % reg2.w

// 32-bit: remainder in reg4
reg1 = reg3 % reg2

// 64-bit: remainder in RDX
rax = rcx % rbx

// ── mod keyword (same as %) ──────────────────────────────────────

reg1.w = reg3.w mod reg2.w

// ── smod keyword (signed modulo, always IDIV) ────────────────────

reg1.w = reg3.w smod reg2.w

// ── with memory operands ─────────────────────────────────────────

reg1.w = [dividend] % [divisor]
