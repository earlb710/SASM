// testFloatingPoint.sasm
// Project : Test-projects
//
// Demonstrates the float and double data types for floating-point
// storage.  SASM's `float` (4-byte IEEE 754 single-precision) maps
// to NASM DD, and `double` (8-byte IEEE 754 double-precision) maps
// to NASM DQ.
//
// Floating-point constants are expressed using NASM's built-in
// __float32__() and __float64__() macros.  The x87 FPU instructions
// (fld, fadd, fstp, etc.) are passed through to NASM verbatim and
// may be used to operate on these values.
//
// Target: 32-bit Linux ELF executable (uses int 0x80 for exit).
//
// Build with:
//   nasm -f elf32 testFloatingPoint.asm -o testFloatingPoint.o
//   ld -m elf_i386 testFloatingPoint.o -o testFloatingPoint
//
// NOTE: This file tests SASM-to-NASM translation only.
//       Running the executable requires Linux with x87 FPU support.

section .data

// ── Scalar float and double variables ───────────────────────────

var pi      as float  = __float32__(3.14159)
var e_value as double = __float64__(2.71828)

// Zero-initialized scalars
var result_f as float
var result_d as double

// ── Float and double arrays ─────────────────────────────────────

data angles as float[4]
data coeffs as double[3]

// Initialized float array (3 values)
data unit_vec as float = __float32__(1.0), __float32__(0.0), __float32__(0.0)

// Initialized double array
data constants as double = __float64__(3.14159265358979), __float64__(2.71828182845905)

// Multi-dimensional float array (2×3 = 6 floats)
data matrix as float[2][3]

// ── Integer data for comparison ─────────────────────────────────

var exit_code as dword = 0

section .text
global _start

_start:
    // ── Load float, add, store ──────────────────────────────────
    // x87 FPU instructions pass through to NASM verbatim.
    fld dword [pi]              // push pi onto FPU stack (ST0 = 3.14159)
    fld dword [unit_vec]        // push 1.0 onto FPU stack (ST0 = 1.0, ST1 = 3.14159)
    faddp                       // ST0 = 1.0 + 3.14159 = 4.14159
    fstp dword [result_f]       // pop and store result

    // ── Load double, store ──────────────────────────────────────
    fld qword [e_value]         // push e (double) onto FPU stack
    fstp qword [result_d]       // pop and store as double

    // ── Exit cleanly ────────────────────────────────────────────
    move 1 to eax               // sys_exit
    move 0 to ebx               // exit code 0
    interrupt 0x80
