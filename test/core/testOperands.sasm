// testOperands.sasm
// Project : Test-projects
//
// Demonstrates expression assignments with variable (memory) operands
// and the comma-separated swap syntax.

section .text
global _start

(* //---------------------------------------------------------------
   Data section: variables used as operands in expressions.
   //--------------------------------------------------------------- *)
var counter as word = 0
var value1  as word = 10
var value2  as word = 20
var result  as word = 0

(* //---------------------------------------------------------------
   Extended var syntax: optional "as", signed/unsigned modifiers.
   //--------------------------------------------------------------- *)
var signedVal as word signed = -10
var unsgnVal  as word unsigned = 200
var shortVar  word = 50
var shortSgn  word signed = -5
var noInit    word signed
var noInitAs  as dword

(* //---------------------------------------------------------------
   test_expressions — exercises variable operands in expressions.
   //--------------------------------------------------------------- *)
proc test_expressions {
    // simple assignment from variable
    ax = [value1]                     // ax = 10

    // add with variable operand
    ax = [value1] + [value2]          // ax = 10 + 20 = 30

    // subtract with variable operand
    bx = [value2] - [value1]          // bx = 20 - 10 = 10

    // variable as destination
    [result] = ax                     // result = 30

    // increment variable through register
    ax = [counter] + 1                // ax = 0 + 1 = 1
    [counter] = ax                    // counter = 1

    // multiply with variable operand
    ax = [value1] * 3                 // ax = 10 * 3 = 30

    // bitwise AND with variable
    ax = [value1] && 0xFF             // ax = 10 & 0xFF = 10

    // bitwise OR with variable
    ax = [value2] || 0x100            // ax = 20 | 0x100 = 276

    // bitwise XOR with variable
    ax = [value1] ^^ 0xFF             // ax = 10 ^ 0xFF = 245

    // bitwise XOR optimized (dst == op1)
    ax = ax ^^ 0xFF                   // ax = ax ^ 0xFF

    // shift with variable operand
    ax = [value1] << 2                // ax = 10 << 2 = 40

    // bitwise NOT
    ax = ![value1]                    // ax = ~10

    // bare variable names (auto-wrapped in brackets)
    ax = value1                       // ax = 10 (bare name → [value1])
    ax = value1 + value2              // ax = 10 + 20 = 30 (bare names)
    bx = value2 - value1              // bx = 20 - 10 = 10
    result = ax                       // result = 30 (bare dest)
    ax = signedVal + unsgnVal         // ax = -10 + 200 = 190
    ax = value1 + value2 - 5          // chained: ax = 10 + 20 - 5 = 25
    ax = value1 * 3                   // ax = 10 * 3 = 30 (bare multiply)
    ax = !value1                      // ax = ~10 (bare NOT)

    // signed-aware operations: div auto-selects IDIV when operand is signed
    ax = signedVal div 5              // signed dividend → CWD + IDIV
    ax = value1 div 5                 // unsigned dividend → XOR DX,DX + DIV
    ax = 100 div signedVal            // signed divisor → CWD + IDIV

    // explicit signed division with sdiv keyword
    ax = unsgnVal sdiv 10             // explicit sdiv → always CWD + IDIV

    // signed-aware right shift: SAR for signed vars, SHR for unsigned
    ax = signedVal >> 2               // signed → SAR ax, 2
    ax = value1 >> 2                  // unsigned → SHR ax, 2
    ax = signedVal >> 2 + 1           // chained: signed → SAR, then ADD

    return
}

(* //---------------------------------------------------------------
   test_swap — exercises comma-separated swap syntax.
   //--------------------------------------------------------------- *)
proc test_swap {
    move 0x1234 to ax
    move 0x5678 to cx

    swap ax, cx                       // ax ↔ cx: ax=0x5678, cx=0x1234

    swap ax and cx                    // swap back using "and" syntax

    return
}

(* //---------------------------------------------------------------
   _start — entry point
   //--------------------------------------------------------------- *)
_start:
    call test_expressions
    call test_swap

    // Exit (Linux syscall: sys_exit)
    move 0 to bl                      // exit code 0
    move 1 to ax                      // sys_exit
    syscall 0x80
