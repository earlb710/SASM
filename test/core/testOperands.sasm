// testOperands.sasm
// Project : Test-projects
//
// Demonstrates expression assignments with variable (memory) operands
// and the comma-separated swap syntax.

section .text
global _start

(* //---------------------------------------------------------------
   Data section: variables used as operands in expressions.
   //--------------------------------------------------------------- *)
var counter as word = 0
var value1  as word = 10
var value2  as word = 20
var result  as word = 0

(* //---------------------------------------------------------------
   Extended var syntax: optional "as", signed/unsigned modifiers.
   //--------------------------------------------------------------- *)
var signedVal as word signed = -10
var unsgnVal  as word unsigned = 200
var shortVar  word = 50
var shortSgn  word signed = -5
var noInit    word signed
var noInitAs  as dword

(* //---------------------------------------------------------------
   test_expressions — exercises variable operands in expressions.
   //--------------------------------------------------------------- *)
proc test_expressions {
    // simple assignment from variable
    reg1.w = [value1]                     // reg1.w = 10

    // add with variable operand
    reg1.w = [value1] + [value2]          // reg1.w = 10 + 20 = 30

    // subtract with variable operand
    reg2.w = [value2] - [value1]          // reg2.w = 20 - 10 = 10

    // variable as destination
    [result] = reg1.w                     // result = 30

    // increment variable through register
    reg1.w = [counter] + 1                // reg1.w = 0 + 1 = 1
    [counter] = reg1.w                    // counter = 1

    // multiply with variable operand
    reg1.w = [value1] * 3                 // reg1.w = 10 * 3 = 30

    // bitwise AND with variable
    reg1.w = [value1] && 0xFF             // reg1.w = 10 & 0xFF = 10

    // bitwise OR with variable
    reg1.w = [value2] || 0x100            // reg1.w = 20 | 0x100 = 276

    // bitwise XOR with variable
    reg1.w = [value1] ^^ 0xFF             // reg1.w = 10 ^ 0xFF = 245

    // bitwise XOR optimized (dst == op1)
    reg1.w = reg1.w ^^ 0xFF                   // reg1.w = reg1.w ^ 0xFF

    // shift with variable operand
    reg1.w = [value1] << 2                // reg1.w = 10 << 2 = 40

    // bitwise NOT
    reg1.w = ![value1]                    // reg1.w = ~10

    // bracketed variable names (required for expression assignment)
    reg1.w = [value1]                     // reg1.w = 10
    reg1.w = [value1] + [value2]          // reg1.w = 10 + 20 = 30
    reg2.w = [value2] - [value1]          // reg2.w = 20 - 10 = 10
    [result] = reg1.w                     // result = 30
    reg1.w = [signedVal] + [unsgnVal]     // reg1.w = -10 + 200 = 190
    reg1.w = [value1] + [value2] - 5      // chained: reg1.w = 10 + 20 - 5 = 25
    reg1.w = [value1] * 3                 // reg1.w = 10 * 3 = 30
    reg1.w = ![value1]                    // reg1.w = ~10

    // signed-aware operations: div auto-selects IDIV when operand is signed
    reg1.w = [signedVal] div 5            // signed dividend → CWD + IDIV
    reg1.w = [value1] div 5               // unsigned dividend → XOR reg4.w,reg4.w + DIV
    reg1.w = 100 div [signedVal]          // signed divisor → CWD + IDIV

    // explicit signed division with sdiv keyword
    reg1.w = [unsgnVal] sdiv 10           // explicit sdiv → always CWD + IDIV

    // signed-aware right shift: SAR for signed vars, SHR for unsigned
    reg1.w = [signedVal] >> 2             // signed → SAR reg1.w, 2
    reg1.w = [value1] >> 2                // unsigned → SHR reg1.w, 2
    reg1.w = [signedVal] >> 2 + 1         // chained: signed → SAR, then ADD

    return
}

(* //---------------------------------------------------------------
   test_swap — exercises comma-separated swap syntax.
   //--------------------------------------------------------------- *)
proc test_swap {
    move 0x1234 to reg1.w
    move 0x5678 to reg3.w

    swap reg1.w, reg3.w                       // reg1.w ↔ reg3.w: reg1.w=0x5678, reg3.w=0x1234

    swap reg1.w and reg3.w                    // swap back using "and" syntax

    return
}

(* //---------------------------------------------------------------
   _start — entry point
   //--------------------------------------------------------------- *)
_start:
    call test_expressions
    call test_swap

    // Exit (Linux syscall: sys_exit)
    move 0 to reg2.b                      // exit code 0
    move 1 to reg1.w                      // sys_exit
    syscall 0x80
