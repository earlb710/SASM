// testMath.sasm
// Project : Test-projects
//
// Demonstrates the math library's integer, float, and double routines
// using the proc-parameter call form for all @math invocations.
//
// Positional by-value / by-pointer call convention:
//   call @math.proc( [var] )   -- by value: pass the value stored at var
//   call @math.proc( var )     -- by pointer: pass the address of var
//   call @math.proc( 5 )       -- literal value (also by value)
//   [dst] = @math.proc( [src] )  -- typed-parameter (FPU) style (always by value)
//   [dst] = @math.f1( [a] ) + @math.f2( [b] ) -- FPU expression
//
// See also: testMathFPU.sasm -- exercises the additional FPU functions
//   (abs_float, neg_float, round, floor, ceil, trunc, sincos, atan,
//    atan2, ln, log2, log10, exp, pow, add_float, sub_float,
//    mul_float, div_float).
//
// Target: 32-bit Linux ELF executable (uses int 0x80 for exit).
//
// Build with:
//   nasm -f elf32 testMath.asm -o testMath.o
//   ld -m elf_i386 testMath.o -o testMath
//
// NOTE: This file tests SASM-to-NASM translation only.
//       Running the executable requires Linux with x87 FPU support.

#REF lib/math.sasm math

section .data

var result_sq    as dword = 0
var result_sqrt  as dword = 0
var result_max   as dword = 0
var result_min   as dword = 0
var result_maxa  as dword = 0
var result_mina  as dword = 0
var val_f        as float = __float32__(3.0)
var result_sqf   as float
var result_sqrtf as float
var val_9f       as float = __float32__(9.0)
var result_maxf  as float
var result_minf  as float
var result_mxaf  as float
var result_mnaf  as float
var val_a        as float = __float32__(7.0)
var val_b        as float = __float32__(2.5)

// Integer array for max_array / min_array tests
data int_arr as dword = 5, 3, 9, 1, 7

// Float array for max_array_float / min_array_float tests
data float_arr as float = __float32__(1.5), __float32__(8.0), __float32__(3.25), __float32__(6.0)

// Double variables for max_float / min_float with double-precision tests
var dval_a       as double = __float64__(7.0)
var dval_b       as double = __float64__(2.5)
var result_maxd  as double
var result_mind  as double
var result_mxad  as double
var result_mnad  as double

// Double array for max_array_double / min_array_double tests
data double_arr as double = __float64__(1.5), __float64__(8.0), __float64__(3.25), __float64__(6.0)

// Double variables for square_float / sqrt with double-precision tests
var val_d         as double = __float64__(3.0)
var val_9d        as double = __float64__(9.0)
var result_sqd    as double
var result_sqrtd  as double

// Trig test values (pi/2 = 1.5707963, 0.0, pi/4 = 0.7853982)
var angle_half_pi as float = __float32__(1.5707963)
var angle_zero    as float = __float32__(0.0)
var angle_quarter as float = __float32__(0.7853982)
var result_sinf   as float
var result_cosf   as float
var result_tanf   as float

// Combined expression test: sin(pi/2) + cos(0) = 1.0 + 1.0 = 2.0
var result_sincos as float

// Double trig test values
var angle_half_pi_d as double = __float64__(1.5707963267948966)
var angle_zero_d    as double = __float64__(0.0)
var angle_quarter_d as double = __float64__(0.7853981633974483)
var result_sind     as double
var result_cosd     as double
var result_tand     as double


var arr_count      as dword = 5

section .text

start:

    // =========================================================
    //  Integer tests -- square / sqrt_int
    //  Using positional by-value syntax: literal 7 = "by value"
    // =========================================================

    // -- square: 7^2 = 49 -----------------------------------------
    call @math.square( 7 )           // in eax=7 (by value, literal)
    move eax to dword [result_sq]

    // -- square: 256^2 = 65536 ------------------------------------
    call @math.square( 256 )         // out eax = 65536

    // -- sqrt_int: sqrt(49) = 7 -----------------------------------
    call @math.sqrt_int( 49 )        // in eax=49 (by value, literal)
    move eax to dword [result_sqrt]

    // -- sqrt_int: sqrt(100) = 10 ---------------------------------
    call @math.sqrt_int( 100 )       // out eax = 10

    // -- sqrt_int: sqrt(2) = 1 (nearest integer) ------------------
    call @math.sqrt_int( 2 )         // out eax = 1

    // -- chain: sqrt(square(5)) = 5 -------------------------------
    call @math.square( 5 )           // out eax = 25
    call @math.sqrt_int              // eax = 25 from square; out eax = 5

    // =========================================================
    //  Integer tests -- max / min (two values)
    //  Positional: first arg -> in eax, second arg -> in ebx
    // =========================================================

    // -- max(10, 20) = 20 -----------------------------------------
    call @math.max( 10, 20 )         // in eax=10, in ebx=20 (both by value, literals)
    move eax to dword [result_max]

    // -- max(30, 5) = 30 ------------------------------------------
    call @math.max( 30, 5 )          // out eax = 30

    // -- min(10, 20) = 10 -----------------------------------------
    call @math.min( 10, 20 )         // in eax=10, in ebx=20
    move eax to dword [result_min]

    // -- min(30, 5) = 5 -------------------------------------------
    call @math.min( 30, 5 )          // out eax = 5

    // =========================================================
    //  Integer tests -- max_array / min_array
    //  int_arr (no brackets) = by pointer: pass the array address
    //  5 (no brackets) = by value: literal count
    //  [arr_count] (brackets) = by value: load count from memory
    // =========================================================

    // -- max_array([5, 3, 9, 1, 7]) = 9 ---------------------------
    call @math.max_array( int_arr, 5 )  // in esi=int_arr (ptr), in ecx=5 (val)
    move eax to dword [result_maxa]

    // -- min_array([5, 3, 9, 1, 7]) = 1 ---------------------------
    call @math.min_array( int_arr, 5 )  // in esi=int_arr (ptr), in ecx=5 (val)
    move eax to dword [result_mina]

    // -- max_array with count loaded from variable (by-value [var]) --
    call @math.max_array( int_arr, [arr_count] )  // ecx = [arr_count] = 5 (by value)

    // =========================================================
    //  Float tests -- square_float / sqrt
    //  FPU expression form: [dst] = @math.proc( [src] )
    // =========================================================

    // -- square_float: 3.0^2 = 9.0 --------------------------------
    [result_sqf] = @math.square_float( [val_f] )

    // -- sqrt: sqrt(9.0) = 3.0 ------------------------------------
    [result_sqrtf] = @math.sqrt( [val_9f] )

    // -- chain: sqrt(square_float(3.0)) = 3.0 ---------------------
    [result_sqf] = @math.square_float( [val_f] )   // 9.0 in result_sqf
    [result_sqrtf] = @math.sqrt( [result_sqf] )     // sqrt(result_sqf=9.0) = 3.0

    // =========================================================
    //  Float tests -- max_float / min_float (two values)
    //  [val_a] = by value: load float from val_a
    //  [val_b] = by value: load float from val_b
    // =========================================================

    // -- max_float(7.0, 2.5) = 7.0 --------------------------------
    [result_maxf] = @math.max_float( [val_a], [val_b] )

    // -- min_float(7.0, 2.5) = 2.5 --------------------------------
    [result_minf] = @math.min_float( [val_a], [val_b] )

    // =========================================================
    //  Float tests -- max_array_float / min_array_float
    //  float_arr (no brackets) = by pointer: pass array address
    //  4 (no brackets) = by value: literal count
    // =========================================================

    // -- max_array_float([1.5, 8.0, 3.25, 6.0]) = 8.0 ------------
    call @math.max_array_float( float_arr, 4 )   // esi=float_arr (ptr), ecx=4 (val)
    fstp dword [result_mxaf]

    // -- min_array_float([1.5, 8.0, 3.25, 6.0]) = 1.5 ------------
    call @math.min_array_float( float_arr, 4 )   // esi=float_arr (ptr), ecx=4 (val)
    fstp dword [result_mnaf]

    // =========================================================
    //  Double tests -- max_float / min_float with doubles
    //  [dval_a] / [dval_b] = by value (FPU, qword)
    // =========================================================

    // -- max_float with doubles: max(7.0, 2.5) = 7.0 -------------
    [result_maxd] = @math.max_float( [dval_a], [dval_b] )

    // -- min_float with doubles: min(7.0, 2.5) = 2.5 -------------
    [result_mind] = @math.min_float( [dval_a], [dval_b] )

    // =========================================================
    //  Double tests -- max_array_double / min_array_double
    //  double_arr (no brackets) = by pointer: pass array address
    //  4 = by value: literal count
    // =========================================================

    // -- max_array_double([1.5, 8.0, 3.25, 6.0]) = 8.0 ----------
    call @math.max_array_double( double_arr, 4 )  // esi=double_arr (ptr), ecx=4 (val)
    fstp qword [result_mxad]

    // -- min_array_double([1.5, 8.0, 3.25, 6.0]) = 1.5 ----------
    call @math.min_array_double( double_arr, 4 )  // esi=double_arr (ptr), ecx=4 (val)
    fstp qword [result_mnad]

    // =========================================================
    //  Trig tests -- sin / cos / tan
    //  [angle_*] = by value (FPU: fld dword [angle_*])
    // =========================================================

    // -- sin(pi/2) = 1.0 ------------------------------------------
    [result_sinf] = @math.sin( [angle_half_pi] )

    // -- cos(0) = 1.0 ---------------------------------------------
    [result_cosf] = @math.cos( [angle_zero] )

    // -- tan(pi/4) = 1.0 ------------------------------------------
    [result_tanf] = @math.tan( [angle_quarter] )

    // =========================================================
    //  Combined FPU expression: sin + cos
    //  sin(pi/2) + cos(0) = 1.0 + 1.0 = 2.0
    // =========================================================
    [result_sincos] = @math.sin( [angle_half_pi] ) + @math.cos( [angle_zero] )

    // =========================================================
    //  Double tests -- sqrt / square_float with double-precision
    //  [val_d] / [val_9d] = by value (FPU, qword)
    // =========================================================

    // -- square_float with double: 3.0^2 = 9.0 -------------------
    [result_sqd] = @math.square_float( [val_d] )

    // -- sqrt with double: sqrt(9.0) = 3.0 -----------------------
    [result_sqrtd] = @math.sqrt( [val_9d] )

    // -- chain with doubles: sqrt(square_float(3.0)) = 3.0 -------
    [result_sqd]   = @math.square_float( [val_d] )  // 9.0 in result_sqd
    [result_sqrtd] = @math.sqrt( [result_sqd] )      // sqrt(result_sqd=9.0) = 3.0

    // =========================================================
    //  Double trig tests -- sin / cos / tan with double-precision
    //  [angle_*_d] = by value (FPU, qword)
    // =========================================================

    // -- sin with double: sin(pi/2) = 1.0 -------------------------
    [result_sind] = @math.sin( [angle_half_pi_d] )

    // -- cos with double: cos(0) = 1.0 ----------------------------
    [result_cosd] = @math.cos( [angle_zero_d] )

    // -- tan with double: tan(pi/4) = 1.0 -------------------------
    [result_tand] = @math.tan( [angle_quarter_d] )

exit:
    // -- exit cleanly ---------------------------------------------
    move 1 to eax                  // sys_exit
    move 0 to ebx                  // exit code 0
    interrupt 0x80
