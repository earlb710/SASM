// testMath.sasm
// Project : Test-projects
//
// Demonstrates the math library's integer, float, and double routines,
// including max, min, and array variants.
// Verifies that the correct library functions are called when using
// the overloaded float/double parameter signatures.
//
// See also: testMathFPU.sasm — exercises the additional FPU functions
//   (abs_float, neg_float, round, floor, ceil, trunc, sincos, atan,
//    atan2, ln, log2, log10, exp, pow, add_float, sub_float,
//    mul_float, div_float).
//
// Usage:
//     #REF lib/math.sasm math
//
// The library provides:
//   Integer:
//     @math.square       — unsigned integer square (EAX → EAX)
//     @math.sqrt_int     — integer square root via x87 FPU (EAX → EAX)
//     @math.max          — max of two signed integers (EAX, EBX → EAX)
//     @math.min          — min of two signed integers (EAX, EBX → EAX)
//     @math.max_array    — max of signed dword array (ESI, ECX → EAX)
//     @math.min_array    — min of signed dword array (ESI, ECX → EAX)
//   Float/Double (x87 FPU stack):
//     @math.square_float      — float square (ST(0) → ST(0))
//     @math.sqrt              — float/double square root (ST(0) → ST(0))
//     @math.sin               — sine (ST(0) → ST(0), radians)
//     @math.cos               — cosine (ST(0) → ST(0), radians)
//     @math.tan               — tangent (ST(0) → ST(0), radians)
//     @math.max_float         — max of two floats/doubles (ST(0), ST(1) → ST(0))
//     @math.min_float         — min of two floats/doubles (ST(0), ST(1) → ST(0))
//     @math.max_array_float   — max of float array (ESI, ECX → ST(0))
//     @math.min_array_float   — min of float array (ESI, ECX → ST(0))
//     @math.max_array_double  — max of double array (ESI, ECX → ST(0))
//     @math.min_array_double  — min of double array (ESI, ECX → ST(0))
//
// Target: 32-bit Linux ELF executable (uses int 0x80 for exit).
//
// Build with:
//   nasm -f elf32 testMath.asm -o testMath.o
//   ld -m elf_i386 testMath.o -o testMath
//
// NOTE: This file tests SASM-to-NASM translation only.
//       Running the executable requires Linux with x87 FPU support.

#REF lib/math.sasm math

section .data

var result_sq    as dword = 0
var result_sqrt  as dword = 0
var result_max   as dword = 0
var result_min   as dword = 0
var result_maxa  as dword = 0
var result_mina  as dword = 0
var val_f        as float = __float32__(3.0)
var result_sqf   as float
var result_sqrtf as float
var val_9f       as float = __float32__(9.0)
var result_maxf  as float
var result_minf  as float
var result_mxaf  as float
var result_mnaf  as float
var val_a        as float = __float32__(7.0)
var val_b        as float = __float32__(2.5)

// Integer array for max_array / min_array tests
data int_arr as dword = 5, 3, 9, 1, 7

// Float array for max_array_float / min_array_float tests
data float_arr as float = __float32__(1.5), __float32__(8.0), __float32__(3.25), __float32__(6.0)

// Double variables for max_float / min_float with double-precision tests
var dval_a       as double = __float64__(7.0)
var dval_b       as double = __float64__(2.5)
var result_maxd  as double
var result_mind  as double
var result_mxad  as double
var result_mnad  as double

// Double array for max_array_double / min_array_double tests
data double_arr as double = __float64__(1.5), __float64__(8.0), __float64__(3.25), __float64__(6.0)

// Double variables for square_float / sqrt with double-precision tests
var val_d         as double = __float64__(3.0)
var val_9d        as double = __float64__(9.0)
var result_sqd    as double
var result_sqrtd  as double

// Trig test values (π/2 ≈ 1.5707963…, 0.0, π/4 ≈ 0.7853982)
var angle_half_pi as float = __float32__(1.5707963)
var angle_zero    as float = __float32__(0.0)
var angle_quarter as float = __float32__(0.7853982)
var result_sinf   as float
var result_cosf   as float
var result_tanf   as float

// Double trig test values
var angle_half_pi_d as double = __float64__(1.5707963267948966)
var angle_zero_d    as double = __float64__(0.0)
var angle_quarter_d as double = __float64__(0.7853981633974483)
var result_sind     as double
var result_cosd     as double
var result_tand     as double

section .text

start:

    // ═════════════════════════════════════════════════════════════
    //  Integer tests — square / sqrt_int
    // ═════════════════════════════════════════════════════════════

    // ── square: 7² = 49 ─────────────────────────────────────────
    move 7 to eax
    call @math.square              // eax = 49, edx = 0
    move eax to dword [result_sq]  // store result

    // ── square: 256² = 65536 ────────────────────────────────────
    move 256 to eax
    call @math.square              // eax = 65536, edx = 0

    // ── sqrt_int: sqrt(49) = 7 ─────────────────────────────────
    move 49 to eax
    call @math.sqrt_int            // eax = 7
    move eax to dword [result_sqrt]

    // ── sqrt_int: sqrt(100) = 10 ────────────────────────────────
    move 100 to eax
    call @math.sqrt_int            // eax = 10

    // ── sqrt_int: sqrt(2) ≈ 1 ──────────────────────────────────
    move 2 to eax
    call @math.sqrt_int            // eax = 1 (nearest integer)

    // ── chain: sqrt(square(5)) = 5 ─────────────────────────────
    move 5 to eax
    call @math.square              // eax = 25
    call @math.sqrt_int            // eax = 5

    // ═════════════════════════════════════════════════════════════
    //  Integer tests — max / min (two values)
    // ═════════════════════════════════════════════════════════════

    // ── max(10, 20) = 20 ────────────────────────────────────────
    move 10 to eax
    move 20 to ebx
    call @math.max                 // eax = 20
    move eax to dword [result_max]

    // ── max(30, 5) = 30 ─────────────────────────────────────────
    move 30 to eax
    move 5 to ebx
    call @math.max                 // eax = 30

    // ── min(10, 20) = 10 ────────────────────────────────────────
    move 10 to eax
    move 20 to ebx
    call @math.min                 // eax = 10
    move eax to dword [result_min]

    // ── min(30, 5) = 5 ──────────────────────────────────────────
    move 30 to eax
    move 5 to ebx
    call @math.min                 // eax = 5

    // ═════════════════════════════════════════════════════════════
    //  Integer tests — max_array / min_array
    // ═════════════════════════════════════════════════════════════

    // ── max_array([5, 3, 9, 1, 7]) = 9 ─────────────────────────
    move int_arr to esi
    move 5 to ecx
    call @math.max_array           // eax = 9
    move eax to dword [result_maxa]

    // ── min_array([5, 3, 9, 1, 7]) = 1 ─────────────────────────
    move int_arr to esi
    move 5 to ecx
    call @math.min_array           // eax = 1
    move eax to dword [result_mina]

    // ═════════════════════════════════════════════════════════════
    //  Float tests — square_float / sqrt
    // ═════════════════════════════════════════════════════════════

    // ── square_float: 3.0² = 9.0 ───────────────────────────────
    fld dword [val_f]              // ST(0) = 3.0
    call @math.square_float        // ST(0) = 9.0
    fstp dword [result_sqf]        // store result

    // ── sqrt: √9.0 = 3.0 ───────────────────────────────────────
    fld dword [val_9f]             // ST(0) = 9.0
    call @math.sqrt                // ST(0) = 3.0
    fstp dword [result_sqrtf]      // store result

    // ── chain: sqrt(square_float(3.0)) = 3.0 ───────────────────
    fld dword [val_f]              // ST(0) = 3.0
    call @math.square_float        // ST(0) = 9.0
    call @math.sqrt                // ST(0) = 3.0
    fstp dword [result_sqrtf]      // store result

    // ═════════════════════════════════════════════════════════════
    //  Float tests — max_float / min_float (two values)
    // ═════════════════════════════════════════════════════════════

    // ── max_float(2.5, 7.0) = 7.0 ──────────────────────────────
    fld dword [val_a]              // push 7.0
    fld dword [val_b]              // push 2.5  (ST(0)=2.5, ST(1)=7.0)
    call @math.max_float           // ST(0) = 7.0
    fstp dword [result_maxf]       // store result

    // ── min_float(2.5, 7.0) = 2.5 ──────────────────────────────
    fld dword [val_a]              // push 7.0
    fld dword [val_b]              // push 2.5  (ST(0)=2.5, ST(1)=7.0)
    call @math.min_float           // ST(0) = 2.5
    fstp dword [result_minf]       // store result

    // ═════════════════════════════════════════════════════════════
    //  Float tests — max_array_float / min_array_float
    // ═════════════════════════════════════════════════════════════

    // ── max_array_float([1.5, 8.0, 3.25, 6.0]) = 8.0 ──────────
    move float_arr to esi
    move 4 to ecx
    call @math.max_array_float     // ST(0) = 8.0
    fstp dword [result_mxaf]       // store result

    // ── min_array_float([1.5, 8.0, 3.25, 6.0]) = 1.5 ──────────
    move float_arr to esi
    move 4 to ecx
    call @math.min_array_float     // ST(0) = 1.5
    fstp dword [result_mnaf]       // store result

    // ═════════════════════════════════════════════════════════════
    //  Double tests — max_float / min_float with double-precision
    //  (max_float and min_float work with doubles since the x87
    //   FPU uses 80-bit extended precision internally)
    // ═════════════════════════════════════════════════════════════

    // ── max_float with doubles: max(2.5, 7.0) = 7.0 ─────────────
    fld qword [dval_a]             // push 7.0 (double)
    fld qword [dval_b]             // push 2.5 (double)  (ST(0)=2.5, ST(1)=7.0)
    call @math.max_float           // ST(0) = 7.0
    fstp qword [result_maxd]       // store result as double

    // ── min_float with doubles: min(2.5, 7.0) = 2.5 ─────────────
    fld qword [dval_a]             // push 7.0 (double)
    fld qword [dval_b]             // push 2.5 (double)  (ST(0)=2.5, ST(1)=7.0)
    call @math.min_float           // ST(0) = 2.5
    fstp qword [result_mind]       // store result as double

    // ═════════════════════════════════════════════════════════════
    //  Double tests — max_array_double / min_array_double
    // ═════════════════════════════════════════════════════════════

    // ── max_array_double([1.5, 8.0, 3.25, 6.0]) = 8.0 ──────────
    move double_arr to esi
    move 4 to ecx
    call @math.max_array_double    // ST(0) = 8.0
    fstp qword [result_mxad]       // store result as double

    // ── min_array_double([1.5, 8.0, 3.25, 6.0]) = 1.5 ──────────
    move double_arr to esi
    move 4 to ecx
    call @math.min_array_double    // ST(0) = 1.5
    fstp qword [result_mnad]       // store result as double

    // ═════════════════════════════════════════════════════════════
    //  Trig tests — sin / cos / tan
    // ═════════════════════════════════════════════════════════════

    // ── sin(π/2) ≈ 1.0 ────────────────────────────────────────
    fld dword [angle_half_pi]
    call @math.sin                 // ST(0) = sin(π/2) ≈ 1.0
    fstp dword [result_sinf]

    // ── cos(0) = 1.0 ──────────────────────────────────────────
    fld dword [angle_zero]
    call @math.cos                 // ST(0) = cos(0) = 1.0
    fstp dword [result_cosf]

    // ── tan(π/4) ≈ 1.0 ────────────────────────────────────────
    fld dword [angle_quarter]
    call @math.tan                 // ST(0) = tan(π/4) ≈ 1.0
    fstp dword [result_tanf]

    // ═════════════════════════════════════════════════════════════
    //  Double tests — sqrt / square_float with double-precision
    //  (overloaded: the same FPU routines work with doubles since
    //   the x87 uses 80-bit extended precision internally)
    // ═════════════════════════════════════════════════════════════

    // ── square_float with double: 3.0² = 9.0 ────────────────────
    fld qword [val_d]              // ST(0) = 3.0 (double)
    call @math.square_float        // ST(0) = 9.0
    fstp qword [result_sqd]        // store result as double

    // ── sqrt with double: √9.0 = 3.0 ─────────────────────────────
    fld qword [val_9d]             // ST(0) = 9.0 (double)
    call @math.sqrt                // ST(0) = 3.0
    fstp qword [result_sqrtd]      // store result as double

    // ── chain with doubles: sqrt(square_float(3.0)) = 3.0 ───────
    fld qword [val_d]              // ST(0) = 3.0 (double)
    call @math.square_float        // ST(0) = 9.0
    call @math.sqrt                // ST(0) = 3.0
    fstp qword [result_sqrtd]      // store result as double

    // ═════════════════════════════════════════════════════════════
    //  Double trig tests — sin / cos / tan with double-precision
    // ═════════════════════════════════════════════════════════════

    // ── sin with double: sin(π/2) ≈ 1.0 ────────────────────────
    fld qword [angle_half_pi_d]
    call @math.sin                 // ST(0) = sin(π/2) ≈ 1.0
    fstp qword [result_sind]       // store result as double

    // ── cos with double: cos(0) = 1.0 ──────────────────────────
    fld qword [angle_zero_d]
    call @math.cos                 // ST(0) = cos(0) = 1.0
    fstp qword [result_cosd]       // store result as double

    // ── tan with double: tan(π/4) ≈ 1.0 ────────────────────────
    fld qword [angle_quarter_d]
    call @math.tan                 // ST(0) = tan(π/4) ≈ 1.0
    fstp qword [result_tand]       // store result as double

exit:
    // ── exit cleanly ────────────────────────────────────────────
    move 1 to eax                  // sys_exit
    move 0 to ebx                  // exit code 0
    interrupt 0x80
