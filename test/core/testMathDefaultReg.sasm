// testMathDefaultReg.sasm
// Project : Test-projects
//
// Demonstrates how the math library's default-register annotations
// affect the code generated for formulas that chain multiple functions.
//
// ── Default register mapping for integer math procs ────────────────────────
//   abs_int     (val dword value default reg1)          → result in reg1
//   sign        (val dword value default reg1)          → result in reg1
//   clamp       (val dword value default reg1,
//                val dword lo    default reg2,
//                val dword hi    default reg3)          → result in reg1
//   max         (val dword first default reg1,
//                val dword second default reg2)         → result in reg1
//   min         (val dword first default reg1,
//                val dword second default reg2)         → result in reg1
//
// ── Two call styles ────────────────────────────────────────────────────────
//
//  Style A  –  memory / literal args
//    The translator emits a setup MOV for every argument.
//    Example: call @math.clamp( [val], [lo], [hi] )
//      → MOV reg1, [val]
//        MOV reg2, [lo]
//        MOV reg3, [hi]
//        <clamp inline body>
//    Three setup MOVs generated automatically.
//
//  Style B  –  default-register args  (no setup MOVs)
//    The caller pre-loads values into the expected default registers.
//    When a call argument exactly matches the declared default, the
//    translator suppresses that MOV entirely.
//    Example (after pre-loading reg1/reg2/reg3):
//      call @math.clamp( reg1, reg2, reg3 )
//      → <clamp inline body>          ; zero setup MOVs
//    Chain-friendly: the reg1 result of one function feeds directly into
//    the first parameter of the next without any intermediate MOV.
//
// Target: 32-bit Linux ELF executable (uses int 0x80 for exit).
//
// Build with:
//   nasm -f elf32 testMathDefaultReg.asm -o testMathDefaultReg.o
//   ld -m elf_i386 testMathDefaultReg.o -o testMathDefaultReg
//
// NOTE: This file tests SASM-to-NASM translation only.

#REF lib/math.sasm math

section .data

var x           as dword = -42      // raw signed input
var lo_bound    as dword = 0        // lower clamp boundary
var hi_bound    as dword = 100      // upper clamp boundary
var a_val       as dword = 15       // first operand for max / min
var b_val       as dword = 7        // second operand for max / min

var result1     as dword = 0        // clamp(abs_int(x), lo_bound, hi_bound)
var result2     as dword = 0        // clamp(max(a_val, b_val), 0, 10)
var result3     as dword = 0        // min(sign(a_val), sign(b_val))

section .text

start:

    // ═════════════════════════════════════════════════════════════════════
    //  Formula 1: result1 = clamp(abs_int(x), lo_bound, hi_bound)
    // ═════════════════════════════════════════════════════════════════════

    // ── Style A: memory args ──────────────────────────────────────────────
    // Each argument that differs from the default register causes the
    // translator to emit a setup MOV.
    //
    // Code generated:
    //   MOV reg1, [x]          ← abs_int value param (reg1 default, [x] ≠ reg1)
    //   <abs_int body>         ← CDQ / XOR / SUB; result in reg1
    //   MOV reg2, [lo_bound]   ← clamp lo param ([lo_bound] ≠ reg2 default)
    //   MOV reg3, [hi_bound]   ← clamp hi param ([hi_bound] ≠ reg3 default)
    //   <clamp body>           ← CMP/J* ; result in reg1
    //
    //   Total setup MOVs: 3  (1 for abs_int + 2 for clamp)
    //   (clamp value=reg1 is already the default after abs_int → no 4th MOV)

    call @math.abs_int( [x] )                           // MOV reg1,[x]; abs_int
    call @math.clamp( reg1, [lo_bound], [hi_bound] )     // reg1=default (skip); MOV reg2,[lo_bound]; MOV reg3,[hi_bound]; clamp
    move reg1 to dword [result1]

    // ── Style B: default-register args ────────────────────────────────────
    // Pre-load reg2 and reg3 before the chain; abs_int returns reg1 which
    // feeds clamp's first param directly.  All three call args now match
    // their declared defaults → zero setup MOVs for both calls.
    //
    // Code generated:
    //   MOV reg2, [lo_bound]   ← user's explicit pre-load
    //   MOV reg3, [hi_bound]   ← user's explicit pre-load
    //   MOV reg1, [x]          ← abs_int value param ([x] ≠ reg1, still needed)
    //   <abs_int body>         ← result in reg1
    //   <clamp body>           ← reg1/reg2/reg3 all match defaults → 0 setup MOVs
    //
    //   Total translator-generated setup MOVs for clamp: 0
    //   Net change vs Style A: 2 fewer MOVs in the clamp call

    move dword [lo_bound] to reg2                        // pre-load lo → reg2 (clamp.lo default)
    move dword [hi_bound] to reg3                        // pre-load hi → reg3 (clamp.hi default)
    call @math.abs_int( [x] )                           // MOV reg1,[x]; abs_int → reg1=|x|
    call @math.clamp( reg1, reg2, reg3 )                   // ALL defaults → zero setup MOVs; clamp
    move reg1 to dword [result1]

    // ═════════════════════════════════════════════════════════════════════
    //  Formula 2: result2 = clamp(max(a_val, b_val), 0, 10)
    // ═════════════════════════════════════════════════════════════════════

    // ── Style A: memory args ──────────────────────────────────────────────
    //
    // Code generated:
    //   MOV reg1, [a_val]      ← max first param
    //   MOV reg2, [b_val]      ← max second param
    //   <max body>             ← CMP/JGE; result in reg1
    //   MOV reg2, 0            ← clamp lo param (reg1=default, skip)
    //   MOV reg3, 10           ← clamp hi param
    //   <clamp body>           ← CMP/J* ; result in reg1
    //
    //   Total setup MOVs: 4  (2 for max + 2 for clamp)

    call @math.max( [a_val], [b_val] )                  // MOV reg1,[a_val]; MOV reg2,[b_val]; max
    call @math.clamp( reg1, 0, 10 )                      // reg1=default (skip); MOV reg2,0; MOV reg3,10; clamp
    move reg1 to dword [result2]

    // ── Style B: default-register args ────────────────────────────────────
    // Pre-load all four values; the output of max (reg1) feeds clamp's
    // value param directly.  Both calls have all args matching defaults.
    //
    // Code generated:
    //   MOV reg1, [a_val]      ← user pre-load (same instruction as Style A)
    //   MOV reg2, [b_val]      ← user pre-load
    //   <max body>             ← result in reg1
    //   MOV reg2, 0            ← user pre-load
    //   MOV reg3, 10           ← user pre-load
    //   <clamp body>           ← zero setup MOVs
    //
    //   Total translator-generated setup MOVs: 0  (vs 4 in Style A)
    //   The same register loads are now explicit pre-loads by the caller.

    move dword [a_val] to reg1                           // pre-load a → reg1 (max.first default)
    move dword [b_val] to reg2                           // pre-load b → reg2 (max.second default)
    call @math.max( reg1, reg2 )                          // ALL defaults → zero setup MOVs; max
    move 0 to reg2                                       // pre-load lo=0 → reg2 (clamp.lo default)
    move 10 to reg3                                      // pre-load hi=10 → reg3 (clamp.hi default)
    call @math.clamp( reg1, reg2, reg3 )                   // ALL defaults → zero setup MOVs; clamp
    move reg1 to dword [result2]

    // ═════════════════════════════════════════════════════════════════════
    //  Formula 3: result3 = min(sign(a_val), sign(b_val))
    // ═════════════════════════════════════════════════════════════════════
    //
    // sign has (val dword value default reg1) → result in reg1
    // min  has (val dword first default reg1, val dword second default reg2)
    //
    // Style B: chain via default registers, storing intermediate in reg2.

    call @math.sign( [a_val] )                          // MOV reg1,[a_val]; sign → reg1 = sign(a)
    move reg1 to reg2                                     // save sign(a) in reg2 (min.second default)
    call @math.sign( [b_val] )                          // MOV reg1,[b_val]; sign → reg1 = sign(b)
    call @math.min( reg1, reg2 )                          // ALL defaults → zero setup MOVs; min
    move reg1 to dword [result3]

exit:
    move 1 to reg1                  // sys_exit
    move 0 to reg2                  // exit code 0
    interrupt 0x80
